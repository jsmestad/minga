#!/usr/bin/env python3
"""Fail when generated protocol artifacts are added back to Git."""

from __future__ import annotations

import subprocess
import sys

LEGACY_GENERATED_SOURCE_PATHS = {
    "macos/Sources/Protocol/ProtocolOpcodes.generated.swift",
    "zig/src/protocol_opcodes.zig",
    "zig/src/protocol_schema_test.zig",
}
GENERATED_SOURCE_PREFIXES = (
    ".generated/protocol/",
    "macos/.generated/protocol/",
    "zig/src/generated/",
)


def main() -> int:
    base_ref = sys.argv[1] if len(sys.argv) > 1 else "origin/main"
    violations = sorted(changed_generated_sources(base_ref))

    if not violations:
        return 0

    print("Generated protocol artifacts must not be committed as source.", file=sys.stderr)
    print("Run `mix protocol.gen` to regenerate ignored build artifacts, but do not add them to Git.", file=sys.stderr)
    print("Generated paths changed as tracked source:", file=sys.stderr)
    for path in violations:
        print(f"  - {path}", file=sys.stderr)
    return 1


def changed_generated_sources(base_ref: str) -> set[str]:
    result = subprocess.run(
        ["git", "diff", "--name-status", f"{base_ref}...HEAD"],
        check=True,
        text=True,
        stdout=subprocess.PIPE,
    )

    violations: set[str] = set()
    for line in result.stdout.splitlines():
        if not line.strip():
            continue
        status, *paths = line.split("\t")
        path = paths[-1]
        if generated_source_path(path) and not status.startswith("D"):
            violations.add(path)

    return violations


def generated_source_path(path: str) -> bool:
    if path in LEGACY_GENERATED_SOURCE_PATHS:
        return True

    return path.startswith(GENERATED_SOURCE_PREFIXES)


if __name__ == "__main__":
    raise SystemExit(main())
