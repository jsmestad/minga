<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIconFile</key>
	<string></string>
	<key>CFBundleIconName</key>
	<string>AppIcon</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Minga</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>NSHighResolutionCapable</key>
	<true/>
	<key>NSSupportsAutomaticTermination</key>
	<false/>
	<key>NSSupportsSuddenTermination</key>
	<false/>

	<!-- Document types: "Open With > Minga" in Finder -->
	<key>CFBundleDocumentTypes</key>
	<array>
		<!-- Plain text (catch-all for text files) -->
		<dict>
			<key>CFBundleTypeName</key>
			<string>Plain Text</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.plain-text</string>
			</array>
		</dict>
		<!-- Source code (catch-all for programming languages) -->
		<dict>
			<key>CFBundleTypeName</key>
			<string>Source Code</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.source-code</string>
			</array>
		</dict>
		<!-- Elixir -->
		<dict>
			<key>CFBundleTypeName</key>
			<string>Elixir Source</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.source-code</string>
			</array>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>ex</string>
				<string>exs</string>
				<string>heex</string>
			</array>
		</dict>
		<!-- Zig -->
		<dict>
			<key>CFBundleTypeName</key>
			<string>Zig Source</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>zig</string>
				<string>zon</string>
			</array>
		</dict>
		<!-- Rust -->
		<dict>
			<key>CFBundleTypeName</key>
			<string>Rust Source</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>rs</string>
			</array>
		</dict>
		<!-- Go -->
		<dict>
			<key>CFBundleTypeName</key>
			<string>Go Source</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>go</string>
				<string>mod</string>
			</array>
		</dict>
		<!-- Web languages -->
		<dict>
			<key>CFBundleTypeName</key>
			<string>Web Source</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>js</string>
				<string>jsx</string>
				<string>ts</string>
				<string>tsx</string>
				<string>html</string>
				<string>css</string>
				<string>scss</string>
				<string>json</string>
			</array>
		</dict>
		<!-- Ruby -->
		<dict>
			<key>CFBundleTypeName</key>
			<string>Ruby Source</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>rb</string>
				<string>erb</string>
				<string>gemspec</string>
			</array>
		</dict>
		<!-- Python -->
		<dict>
			<key>CFBundleTypeName</key>
			<string>Python Source</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>py</string>
				<string>pyi</string>
			</array>
		</dict>
		<!-- Swift -->
		<dict>
			<key>CFBundleTypeName</key>
			<string>Swift Source</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.swift-source</string>
			</array>
		</dict>
		<!-- Config/data files -->
		<dict>
			<key>CFBundleTypeName</key>
			<string>Configuration</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>yml</string>
				<string>yaml</string>
				<string>toml</string>
				<string>xml</string>
				<string>csv</string>
				<string>md</string>
				<string>markdown</string>
				<string>txt</string>
				<string>log</string>
				<string>conf</string>
				<string>cfg</string>
				<string>ini</string>
				<string>env</string>
			</array>
		</dict>
		<!-- Shell scripts -->
		<dict>
			<key>CFBundleTypeName</key>
			<string>Shell Script</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.shell-script</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
